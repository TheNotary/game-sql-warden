# This snippet should go in a dotfile
### WASM SDK Install, https://github.com/WebAssembly/wasi-sdk
export WASI_SDK="${HOME}/wasi-sdk"
#export CLANG_LIB_WASI=$WASI_SDK/lib/clang/21/lib/wasm32-unknown-wasip1
export WASI_SYSROOT=$WASI_SDK/share/wasi-sysroot

# WASI p1
export CC_wasm32_wasip1="$WASI_SDK/bin/clang --target=wasm32-wasi --sysroot=$WASI_SDK/share/wasi-sysroot"
export AR_wasm32_wasip1="$WASI_SDK/bin/llvm-ar"
export CARGO_TARGET_WASM32_WASIP1_RUSTFLAGS="-Clink-arg=--target=wasm32-wasi -Clink-arg=--sysroot=$WASI_SDK/share/wasi-sysroot -Clink-arg=-L$WASI_SDK/lib/clang/21/lib/wasm32-unknown-wasip1 -Clink-arg=-lclang_rt.builtins"

# WASIp2
export CC_wasm32_wasip2="$WASI_SDK/bin/clang --target=wasm32-wasi --sysroot=$WASI_SDK/share/wasi-sysroot"
export AR_wasm32_wasip2="$WASI_SDK/bin/llvm-ar"
export CARGO_TARGET_WASM32_WASIP2_RUSTFLAGS="-Clink-arg=--target=wasm32-wasi -Clink-arg=--sysroot=$WASI_SDK/share/wasi-sysroot -Clink-arg=-L$WASI_SDK/lib/clang/21/lib/wasm32-unknown-wasip2 -Clink-arg=-lclang_rt.builtins"
